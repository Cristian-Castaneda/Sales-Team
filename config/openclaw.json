{
  "gateway": {
    "mode": "local",
    "controlUi": {
      "enabled": true
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-haiku-4-5",
        "fallbacks": ["openrouter/meta-llama/llama-3.3-70b-instruct"]
      }
    }
  },
  "tools": {
    "exec": {
      "security": "full"
    }
  },
  "env": {
    "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}",
    "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
    "OPENAI_API_KEY": "${OPENAI_API_KEY}",
    "TELEGRAM_BOT_TOKEN": "${TELEGRAM_BOT_TOKEN}"
  },
  "browser": {
    "enabled": true,
    "profiles": {
      "default": {
        "cdpUrl": "http://browser:3000",
        "color": "#00FF00"
      }
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["+56954130924"]
    },
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["8794533158"],
      "streaming": "off"
    }
  }
}
